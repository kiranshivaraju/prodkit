# ProdKit - Framework files should be tracked
# This .gitignore is for the ProdKit repository itself

# OS files
.DS_Store
Thumbs.db

# IDEs
.vscode/
.idea/
*.swp
*.swo

# These are generated by prodkit init (not part of the source repo)
# Use / prefix so they only match at repo root, not inside src/prodkit/
/.prodkit/
/.speckit/
/.claude/commands/

# Example/test directories that shouldn't be in the framework repo
product/
sprints/
node_modules/
venv/
env/
.env
.env.local

# Python package build artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
